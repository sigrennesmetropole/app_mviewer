<config>
	<application title="Covoiturage"
	             logo="apps/public/img/logo/logo_mviewer_transp.png"
	             favicon="https://public.sig.rennesmetropole.fr/ressources/img/mviewer/favicon_gris.png"
	             titlehelp="À propos des cartes thématiques"
	             help="apps/site_internet/html/site_internet_help.html"
	             showhelp="false"
	             exportpng="false"
	             style="apps/site_internet/css/site_internet_gris.css"
	             measuretools="false"
	             togglealllayersfromtheme="false"
	             templaterightinfopanel="allintabs"
	             sortlayersinfopanel="toc"/>
	<mapoptions maxzoom="20"
	            minzoom="11"
	            projection="EPSG:3857"
	            center="-183890.24433942206,6125725.984905125"
	            zoom="11"/>
	<baselayers style="default">
		<!-- style="default"||gallery" -->
		<baselayer visible="true"
		           id="pvcisimple"
		           thumbgallery="apps/public/img/basemap/pvcisimple.jpg"
		           title="Rennes Metropole"
		           label="Plan de ville"
		           type="WMTS"
		           url="https://public.sig.rennesmetropole.fr/geowebcache/service/wmts"
		           layers="ref_fonds:pvci_simple_gris"
		           format="image/png"
		           style="_null"
		           matrixset="EPSG:3857"
		           fromcapacity="false"
		           attribution="&lt;a href=&quot;https://public.sig.rennesmetropole.fr/geonetwork/srv/fre/catalog.search#/home&quot; target=&quot;_blank&quot; &gt;Rennes Métropole&lt;/a&gt;"
		           maxzoom="22"
		           maxscale="1000"/>
	</baselayers>
	<extensions>
		<extension type="component"
		           id="GUICustom"
		           path="apps/public/addons"/>
		<extension type="javascript"
		           src="apps/public/addons/addOrthophotoBaselayer.js"
		           visible="false"/>
		<extension type="component"
		           id="accessibilite"
		           path="apps/public/addons"/>
	</extensions>
	<themes mini="true">
	
	<!-- Parc relais -->
		<theme id="parc_relais"
		       name="Parc relais"
		       collapsed="false"
			   visible="false"
		       icon="fas fa-parking">
			<layer id="v_parking"
			       name="Parcs relais avec places réservées au covoiturage"
			       type="wms"
			       url="https://public.sig.rennesmetropole.fr/geoserver/trp_statio/ows"
			       visible="true"
			       style="v_parking_usage_parc_relais"
			       filter="usage = 'Parc relais' and etat = 'Existant' and nb_pl_covoit > 0 "
			      
			       infoformat="application/vnd.ogc.gml" 
			       metadata="undefined"
			       metadata-csw="https://public.sig.rennesmetropole.fr/geonetwork/srv/fre/catalog.search#/metadata/ceb9828a-951a-46ed-99e3-dc750d07feb9"
			       queryable="true"
			       featurecount="5"
			       infopanel="right-panel">
				<template url="apps/site_internet/templates/parc_relais.mst"/>
			</layer>
		</theme>
	
	<!-- Dépose minute covoiturage -->
		<theme id="Dépose minute covoiturage" 
				name="Déposes minutes covoiturage" 
				collapsed="false" 
				icon="fas fa-caret-right"> 
       
	   <layer id="v_voirie_stationnement_limite"
		   name="Dépose-minutes covoiturage"
		   type="wms"
		   url="https://public.sig.rennesmetropole.fr/geoserver/trp_statio/ows"	  
		   visible="true"
		   infoformat="application/vnd.ogc.gml" 		  
		   style="trp_statio:v_voirie_stationnement_limite_nb_mv"
		   stylesalias=""
		   metadata="https://public.sig.rennesmetropole.fr/geonetwork/srv/fre/catalog.search#/metadata/d928027a-891f-46a0-afeb-24dd6ef917e3"
		   metadata-csw="https://public.sig.rennesmetropole.fr/geonetwork/srv/fre/csw?SERVICE=CSW&amp;VERSION=2.0.2&amp;REQUEST=GetRecordById&amp;ELEMENTSETNAME=full&amp;ID&amp;ID=d928027a-891f-46a0-afeb-24dd6ef917e3"		  
		   queryable="true"
		   searchable="false"	  
		   useproxy="false"
		   featurecount="5"
		   infopanel="right-panel">
		  <template url="apps/site_internet/templates/station_limite.mst"/>
        </layer> 
      </theme> 
	  
	    <!-- Aires de covoiturage -->
		<theme id="aires"
		       name="Aires de covoiturage"
		       collapsed="false"
			   visible="false"
		       icon="fas fa-car">
			<layer id="v_parking"
			       name="Aires de covoiturage"
			       type="wms"
			       url="https://public.sig.rennesmetropole.fr/geoserver/trp_statio/ows"
			       visible="true"
			       style="v_parking_usage_covoiturage"
			       filter="usage = 'Aire de covoiturage' and etat = 'Existant' and nb_pl_covoit > 0" 
   				   infoformat="application/vnd.ogc.gml" 
			       metadata="undefined"
			       metadata-csw="https://public.sig.rennesmetropole.fr/geonetwork/srv/fre/catalog.search#/metadata/ceb9828a-951a-46ed-99e3-dc750d07feb9"
			       queryable="true"
			       featurecount="5"
			       infopanel="right-panel">
				<template url="apps/site_internet/templates/airecovoiturage.mst"/>
			</layer>
		</theme>
		
		
		
	</themes>
</config>